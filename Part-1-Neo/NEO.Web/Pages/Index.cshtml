@page
@model IndexModel
@{
    ViewData["Title"] = "ProjectNEO Dashboard";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ProjectNEO Dashboard</title>
    <style>

        /* ── BASE ── */
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: #0f0f1a;
            color: #e0e0e0;
            min-height: 100vh;
        }

        /* ── HEADER ── */
        .header {
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            padding: 20px 40px;
            border-bottom: 2px solid #0f3460;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .header h1 { font-size: 26px; color: #00d4ff; letter-spacing: 2px; }
        .header .run-info { font-size: 12px; color: #888; text-align: right; }
        .header .run-info span { color: #00d4ff; }

        /* ── MAIN ── */
        .container { padding: 30px 40px; max-width: 1400px; margin: auto; }

        /* ── SUMMARY CARDS ── */
        .cards {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }
        .card {
            background: #1a1a2e;
            border-radius: 12px;
            padding: 20px;
            border: 1px solid #0f3460;
            text-align: center;
        }
        .card .label { font-size: 12px; color: #888; margin-bottom: 8px; }
        .card .value { font-size: 36px; font-weight: bold; }
        .card.buy   .value { color: #27ae60; }
        .card.watch .value { color: #f39c12; }
        .card.skip  .value { color: #e74c3c; }
        .card.total .value { color: #00d4ff; }

        /* ── SECTION TITLES ── */
        .section-title {
            font-size: 16px;
            font-weight: bold;
            color: #00d4ff;
            margin: 30px 0 15px 0;
            padding-bottom: 8px;
            border-bottom: 1px solid #0f3460;
        }

        /* ── SIGNALS TABLE ── */
        table {
            width: 100%;
            border-collapse: collapse;
            background: #1a1a2e;
            border-radius: 12px;
            overflow: hidden;
        }
        th {
            background: #0f3460;
            padding: 12px 16px;
            text-align: left;
            font-size: 12px;
            color: #00d4ff;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        td {
            padding: 12px 16px;
            font-size: 14px;
            border-bottom: 1px solid #0f3460;
        }
        tr:last-child td { border-bottom: none; }
        tr:hover td { background: #16213e; }

        /* ── SIGNAL BADGES ── */
        .badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
        }
        .badge.BUY   { background: #1a4a2e; color: #27ae60; border: 1px solid #27ae60; }
        .badge.WATCH { background: #4a3a10; color: #f39c12; border: 1px solid #f39c12; }
        .badge.SKIP  { background: #4a1a1a; color: #e74c3c; border: 1px solid #e74c3c; }

        /* ── PCT COLORS ── */
        .pos { color: #27ae60; }
        .neg { color: #e74c3c; }
        .neu { color: #888;    }

        /* ── SECTOR GRID ── */
        .sector-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }
        .sector-card {
            background: #1a1a2e;
            border-radius: 12px;
            padding: 20px;
            border: 1px solid #0f3460;
        }
        .sector-card h3 {
            font-size: 13px;
            color: #00d4ff;
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .sector-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 6px 0;
            border-bottom: 1px solid #0f3460;
            font-size: 13px;
        }
        .sector-row:last-child { border-bottom: none; }
        .sector-bar {
            height: 4px;
            border-radius: 2px;
            margin-top: 4px;
        }

        /* ── SELECTED SECTORS ── */
        .sector-tags { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 30px; }
        .sector-tag {
            background: #0f3460;
            color: #00d4ff;
            padding: 8px 20px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: bold;
            border: 1px solid #00d4ff;
        }

        /* ── FOOTER ── */
        .footer {
            text-align: center;
            padding: 20px;
            color: #444;
            font-size: 12px;
            border-top: 1px solid #0f3460;
            margin-top: 40px;
        }

        /* ── NO DATA ── */
        .no-data {
            text-align: center;
            padding: 40px;
            color: #555;
            font-size: 14px;
        }
    </style>
</head>
<body>

    <!-- ══ HEADER ══ -->
    <div class="header">
        <h1>📈 PROJECT NEO</h1>
        <div class="run-info">
            <div>Run ID: <span>@Model.LastRunId</span></div>
            <div>Date: <span>@Model.LastRunDate.ToString("dddd, dd MMM yyyy")</span></div>
            <div>Generated: <span>@DateTime.Now.ToString("HH:mm")</span></div>
        </div>
    </div>

    <div class="container">

        <!-- ══ SUMMARY CARDS ══ -->
        <div class="cards">
            <div class="card total">
                <div class="label">TOTAL SIGNALS</div>
                <div class="value">@Model.Signals.Count</div>
            </div>
            <div class="card buy">
                <div class="label">🟢 BUY</div>
                <div class="value">@Model.BuyCount</div>
            </div>
            <div class="card watch">
                <div class="label">🟡 WATCH</div>
                <div class="value">@Model.WatchCount</div>
            </div>
            <div class="card skip">
                <div class="label">🔴 SKIP</div>
                <div class="value">@Model.SkipCount</div>
            </div>
        </div>

        <!-- ══ SELECTED SECTORS ══ -->
        <div class="section-title">🎯 Selected Sectors Today</div>
        <div class="sector-tags">
            @if (Model.SelectedSectors.Count == 0)
            {
                <span style="color:#555;">No sectors selected yet</span>
            }
            @foreach (var s in Model.SelectedSectors)
            {
                <span class="sector-tag">@s</span>
            }
        </div>

        <!-- ══ TRADE SIGNALS TABLE ══ -->
        <div class="section-title">📊 Trade Signals</div>

        @if (Model.Signals.Count == 0)
        {
            <div class="no-data">
                ⏳ No signals yet for today. Run the pipeline first.
            </div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Symbol</th>
                        <th>Name</th>
                        <th>Sector</th>
                        <th>Signal</th>
                        <th>Score</th>
                        <th>1D %</th>
                        <th>Reason</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.Signals)
                    {
                        <tr>
                            <td style="color:#555;">@s.Rank</td>
                            <td><strong>@s.Symbol</strong></td>
                            <td style="color:#aaa;">@s.StockName</td>
                            <td style="color:#888; font-size:12px;">@s.SectorName</td>
                            <td><span class="badge @s.Signal">@s.Signal</span></td>
                            <td>@s.Score.ToString("F3")</td>
                            <td class="@(s.Pct1d > 0 ? "pos" : s.Pct1d < 0 ? "neg" : "neu")">
                                @(s.Pct1d > 0 ? "+" : "")@s.Pct1d.ToString("F2")%
                            </td>
                            <td style="color:#777; font-size:12px;">@s.Reason</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <!-- ══ SECTOR PERFORMANCE ══ -->
        <div class="section-title">🌍 Sector Performance</div>
        <div class="sector-grid">

            <!-- US -->
            <div class="sector-card">
                <h3>🇺🇸 US Market</h3>
                @if (Model.SectorsUS.Count == 0)
                {
                    <div style="color:#555; font-size:13px;">No data</div>
                }
                @foreach (var s in Model.SectorsUS)
                {
                    var cls = s.PctChange > 0 ? "pos" : s.PctChange < 0 ? "neg" : "neu";
                    <div class="sector-row">
                        <span>@s.SectorName</span>
                        <span class="@cls">
                            @(s.PctChange > 0 ? "+" : "")@s.PctChange.ToString("F2")%
                        </span>
                    </div>
                }
            </div>

            <!-- INDIA -->
            <div class="sector-card">
                <h3>🇮🇳 India Market</h3>
                @if (Model.SectorsIndia.Count == 0)
                {
                    <div style="color:#555; font-size:13px;">No data</div>
                }
                @foreach (var s in Model.SectorsIndia)
                {
                    var cls = s.PctChange > 0 ? "pos" : s.PctChange < 0 ? "neg" : "neu";
                    <div class="sector-row">
                        <span>@s.SectorName</span>
                        <span class="@cls">
                            @(s.PctChange > 0 ? "+" : "")@s.PctChange.ToString("F2")%
                        </span>
                    </div>
                }
            </div>

            <!-- CHINA -->
            <div class="sector-card">
                <h3>🇨🇳 China Market</h3>
                @if (Model.SectorsChina.Count == 0)
                {
                    <div style="color:#555; font-size:13px;">No data</div>
                }
                @foreach (var s in Model.SectorsChina)
                {
                    var cls = s.PctChange > 0 ? "pos" : s.PctChange < 0 ? "neg" : "neu";
                    <div class="sector-row">
                        <span>@s.SectorName</span>
                        <span class="@cls">
                            @(s.PctChange > 0 ? "+" : "")@s.PctChange.ToString("F2")%
                        </span>
                    </div>
                }
            </div>

        </div>

    </div>

    <!-- ══ FOOTER ══ -->
    <div class="footer">
        ProjectNEO © @DateTime.Now.Year &nbsp;|&nbsp;
        Powered by Alpha Vantage &nbsp;|&nbsp;
        Built with ASP.NET Core
    </div>

</body>
</html>